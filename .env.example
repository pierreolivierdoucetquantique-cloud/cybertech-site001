# ===========================================================
# CYBER TECK Q — Variables d'environnement
# ===========================================================
# Ce fichier est un MODÈLE — il ne contient aucune vraie valeur.
# En local : copiez ce fichier en ".env" et remplissez les valeurs.
# Sur Render : configurez ces variables dans le dashboard
#   (Service → Environment → Add Environment Variable)
#   Ne JAMAIS commiter de vraies valeurs dans Git.
# ===========================================================

# --- Général ---
ENVIRONMENT=production

# --- Base de données ---
# Doit pointer vers un chemin sur le Render Disk monté (voir render.yaml).
# Exemple en production : /data/cyberteckq.db
# Exemple en local : ./data/cyberteckq.db
DATABASE_PATH=./data/cyberteckq.db

# --- Fichiers téléversés (preuves de paiement, images CMS, documents clients) ---
# Doit vivre sur le MÊME Render Disk que la base de données pour être persistant.
# Exemple en production : /app/data/uploads
UPLOADS_DIR=./data/uploads

# --- Sécurité / JWT ---
# OBLIGATOIRE en production. Générez une valeur longue et aléatoire, par exemple avec :
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
# Si cette variable change, toutes les sessions actives sont invalidées.
JWT_SECRET_KEY=remplacez-moi-par-une-valeur-aleatoire-longue

# --- Cookies ---
# True en production (HTTPS uniquement). Mettre False seulement en développement local sans HTTPS.
COOKIE_SECURE=True

# --- Email (Resend) ---
# Clé API obtenue sur https://resend.com — section API Keys.
RESEND_API_KEY=re_votre_cle_api_resend
# Adresse d'expédition technique. DOIT utiliser un domaine VÉRIFIÉ sur Resend
# (cyberteckq.com l'est déjà) — outlook.com ne pourra jamais l'être puisque
# ce domaine appartient à Microsoft, pas à Cyber Teck Q.
EMAIL_FROM=Cyber Teck Q <notifications@cyberteckq.com>
# Adresse affichée comme "répondre à" dans les emails envoyés aux clients —
# c'est ici que leurs réponses arriveront réellement.
EMAIL_REPLY_TO=cyberteckq@outlook.com
# Adresse qui reçoit les notifications internes (nouvelles commandes, formulaires, contact).
ADMIN_NOTIFICATION_EMAIL=cyberteckq@outlook.com

# --- Frontend ---
# URL complète de votre site une fois déployé (utilisée pour CORS et les liens dans les emails).
FRONTEND_URL=https://cyberteckq.com

# --- Paiements : Interac ---
# Adresse courriel affichée au client pour effectuer le virement Interac.
INTERAC_EMAIL=cyberteckq@outlook.com

# --- Paiements : Stripe ---
# Clés obtenues sur https://dashboard.stripe.com/apikeys
# Utilisez les clés "test" (sk_test_/pk_test_) pour essayer le système avant
# de passer aux clés "live" (sk_live_/pk_live_) en production.
STRIPE_SECRET_KEY=sk_test_votre_cle_secrete
STRIPE_PUBLISHABLE_KEY=pk_test_votre_cle_publique
# Secret du endpoint webhook, obtenu en créant un endpoint sur
# https://dashboard.stripe.com/webhooks pointant vers :
#   https://votre-domaine.com/api/webhooks/stripe
# Événement à cocher : checkout.session.completed
STRIPE_WEBHOOK_SECRET=whsec_votre_secret_webhook

# --- Premier compte admin ---
# Utilisé UNIQUEMENT au premier démarrage si aucun admin n'existe encore en base.
# Une fois le compte créé avec succès, vous pouvez retirer ces deux variables
# du dashboard Render (elles ne sont plus nécessaires après la création).
INITIAL_ADMIN_EMAIL=admin@cyberteckq.com
INITIAL_ADMIN_PASSWORD=remplacez-moi-par-un-mot-de-passe-fort
